
# Example environment variables for local development and deployment
# Copy this to `.env` (don't commit secrets) and set real values in Vercel

# MBTA API key
MBTA_API_KEY=your_mbta_api_key_here

# QStash / Upstash configuration
# Optional: Upstash base URL (region-specific)
QSTASH_URL=https://qstash-us-east-1.upstash.io
# Token used to publish schedules via the @upstash/qstash client (keep secret)
QSTASH_TOKEN=your_qstash_publish_token_here
# HMAC signing keys used by QStash for webhook verification
QSTASH_CURRENT_SIGNING_KEY=sig_current_example
QSTASH_NEXT_SIGNING_KEY=sig_next_example

# Boston Transit Optimizer – Environment Variables
# Copy this file to .env.local and fill in the values.


# MBTA V3 API key (optional – increases rate limits)
# Get yours at: https://api-v3.mbta.com/register
MBTA_API_KEY=your_mbta_api_key_here

