# Example environment variables for local development and deployment
# Copy this to `.env` (don't commit secrets) and set real values in Vercel

MBTA_API_KEY=your_mbta_api_key_here

# Preferred: QStash signing key used to verify HMAC-SHA256 signatures
QSTASH_SIGNING_KEY=your_qstash_signing_key_here

# Alternate / fallback: reuse CRON_SECRET if you prefer
CRON_SECRET=your_cron_secret_here
# Boston Transit Optimizer – Environment Variables
# Copy this file to .env.local and fill in the values.

# MBTA V3 API key (optional – increases rate limits)
# Get yours at: https://api-v3.mbta.com/register
MBTA_API_KEY=e31e4950417b4b3e806c3c7d112342fa

# Redis URL (optional – falls back to in-memory cache)
# Example: redis://localhost:6379
REDIS_URL=
